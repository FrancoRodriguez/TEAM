<div class="fade-in">
  <div style="margin-bottom: 4rem; border-left: 3px solid var(--accent); padding-left: 2rem;">
    <h1 style="font-size: 3.5rem; letter-spacing: -1px; margin-bottom: 0.5rem;">Operaciones de Activos</h1>
    <p style="color: var(--secondary); font-size: 1.1rem; font-weight: 300; letter-spacing: 0.5px;">Seguimiento global de Inversiones de Capital (CapEx) y Gastos Operativos (OpEx).</p>
  </div>

  <div class="card" style="margin-bottom: 5rem; padding: 0;">
    <table style="width: 100%; border-collapse: collapse; text-align: left;">
      <thead>
        <tr style="border-bottom: 2px solid var(--border); background: #f8fafc;">
          <th style="padding: 1.5rem 2rem; color: var(--secondary); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">PROPIEDAD</th>
          <th style="padding: 1.5rem 2rem; color: var(--secondary); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">DESCRIPCIÓN</th>
          <th style="padding: 1.5rem 2rem; color: var(--secondary); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px;">CATEGORÍA</th>
          <th style="padding: 1.5rem 2rem; color: var(--secondary); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; text-align: right;">PRESUPUESTO</th>
          <th style="padding: 1.5rem 2rem; color: var(--secondary); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; text-align: center;">ESTADO</th>
        </tr>
      </thead>
      <tbody>
        <% @tickets.each do |ticket| %>
          <tr style="border-bottom: 1px solid var(--border); transition: background 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
            <td style="padding: 1.5rem 2rem; font-family: var(--font-serif); font-weight: 700; font-size: 1.1rem; color: var(--primary);">
              <%= ticket.property.name %>
            </td>
            <td style="padding: 1.5rem 2rem; color: var(--primary); font-weight: 500;">
              <%= ticket.title %>
              <div style="font-size: 0.85rem; color: var(--secondary); font-weight: 300; margin-top: 0.25rem;"><%= ticket.description %></div>
            </td>
            <td style="padding: 1.5rem 2rem;">
              <div class="badge <%= ticket.capex ? 'badge-luxury' : 'badge-blue' %>">
                <%= ticket.capex ? 'CapEx' : 'OpEx' %>
              </div>
            </td>
            <td style="padding: 1.5rem 2rem; font-family: var(--font-serif); font-weight: 700; font-size: 1.25rem; color: var(--primary); text-align: right;">
              €<%= number_with_delimiter(ticket.budget.to_i) %>
            </td>
            <td style="padding: 1.5rem 2rem; text-align: center;">
              <% if ticket.status == 'approved' %>
                <span style="font-size: 0.7rem; font-weight: 700; letter-spacing: 1px; color: var(--success); background: rgba(34, 197, 94, 0.1); padding: 0.5rem 1rem; border-radius: 4px;">APROBADO</span>
              <% elsif ticket.status == 'completed' %>
                <span style="font-size: 0.7rem; font-weight: 700; letter-spacing: 1px; color: var(--primary); background: rgba(15, 23, 42, 0.1); padding: 0.5rem 1rem; border-radius: 4px;">COMPLETADO</span>
              <% else %>
                <span style="font-size: 0.7rem; font-weight: 700; letter-spacing: 1px; color: var(--accent); background: rgba(197, 160, 89, 0.1); padding: 0.5rem 1rem; border-radius: 4px;"><%= ticket.status.upcase %></span>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @tickets.empty? %>
          <tr>
            <td colspan="5" style="padding: 3rem; text-align: center; color: var(--secondary); font-style: italic;">
              No hay operaciones registradas en el portfolio.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
